PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/interim_assessment
# Atlas: prefer the URI from Atlas → Connect → Drivers. If mongodb+srv fails with TLS "internal error"
# from your network, use a direct string with one host and directConnection=true (see Atlas docs).
JWT_SECRET=change_this_to_a_strong_secret
# Comma-separated if you need more than one origin (production + preview URLs)
FRONTEND_URL=http://localhost:5173
